{
  "run": {
    "work_dir": "sot",
    "max_output_chars": 240000,
    "second_pass": true,
    "synthesis": true,
    "knowledge_transfer": {
      "capsules": true,
      "capsule_model_id": "deepseek-v4-pro",
      "allow_archivist_outside_selected": false,
      "capsule_input_max_chars": 160000,
      "capsule_chunk_overlap_chars": 2000,
      "capsule_max_output_chars": 90000,
      "pack_raw_excerpt_chars": 70000,
      "pack_max_chars": 320000,
      "route_peer_knowledge_to_round2": true,
      "route_round_knowledge_to_final": true
    }
  },
  "models": [
    {
      "id": "deepseek-v4-pro",
      "enabled": true,
      "adapter": "opencode",
      "binary": "opencode",
      "model": "deepseek/deepseek-v4-pro"
    },
    {
      "id": "kimi-k2-7",
      "enabled": true,
      "adapter": "kimi",
      "binary": "kimi",
      "model": "kimi-code/kimi-for-coding",
      "council_mode": true,
      "max_prompt_chars": 120000,
      "round2_pack_raw_excerpt_chars": 0,
      "round2_pack_max_chars": 60000
    },
    {
      "id": "glm-5-2-max",
      "enabled": false,
      "adapter": "claude",
      "binary": "claude",
      "model": "opus",
      "effort": "high",
      "safe_mode": true,
      "api_key_env": "ZAI_API_KEY",
      "api_key_file": "~/.codex/team/zai_api_key",
      "api_key_target_env": "ANTHROPIC_AUTH_TOKEN",
      "env": {
        "ANTHROPIC_BASE_URL": "https://api.z.ai/api/anthropic",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.2[1m]",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5.2[1m]",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-5.2[1m]",
        "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000",
        "API_TIMEOUT_MS": "3000000"
      },
      "disallow_model_usage_patterns": ["^glm-4\\."],
      "recover_tool_protocol_error": true,
      "tools": "Read,Grep,Glob,LS"
    },
    {
      "id": "opus-4-8-max",
      "enabled": true,
      "adapter": "claude",
      "binary": "claude",
      "model": "opus",
      "effort": "max",
      "tools": "Read,Grep,Glob,LS,Agent"
    },
    {
      "id": "gpt-5-5-xhigh",
      "enabled": true,
      "adapter": "codex",
      "binary": "codex",
      "model": "gpt-5.5",
      "reasoning_effort": "xhigh",
      "service_tier": "fast"
    }
  ],
  "synthesizer": {
    "id": "codex-synthesizer",
    "adapter": "codex",
    "binary": "codex",
    "model": "gpt-5.5",
    "reasoning_effort": "xhigh",
    "service_tier": "fast"
  }
}
